# PostgreSQL used by the local Docker stack
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=loan_monitoring
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops_password
DATABASE_URL=postgresql+psycopg2://mlops:mlops_password@postgres:5432/loan_monitoring

# Optional Slack incoming webhook for alerting from Airflow/pipeline
SLACK_WEBHOOK_URL=

# Pipeline defaults
MONITORING_REFERENCE_START=2015-01-01
MONITORING_REFERENCE_END=2015-05-31
MONITORING_CURRENT_START=2015-06-01
MONITORING_CURRENT_END=2015-12-31
